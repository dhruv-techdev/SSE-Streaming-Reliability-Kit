# ===========================================
# SSE Streaming Reliability Kit Configuration
# ===========================================

# Server
NODE_ENV=development
PORT=3000
HOST=localhost

# SSE Configuration
SSE_TICK_INTERVAL=2000

# Heartbeat interval (SSRK-114)
# Safe default for most proxies (NGINX timeout is 60s)
# Adjust based on your proxy configuration
SSE_HEARTBEAT_INTERVAL=30000

SSE_RETRY_TIMEOUT=3000
SSE_MAX_BUFFER_SIZE=1000

# Connection Limits
MAX_CONNECTIONS=1000

# Shutdown
SHUTDOWN_GRACE_PERIOD=5000

# Logging
LOG_LEVEL=debug
# Enable heartbeat logging (SSRK-118)
LOG_HEARTBEATS=false
