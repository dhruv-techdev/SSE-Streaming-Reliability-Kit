# ===========================================
# SSE Streaming Reliability Kit Configuration
# ===========================================

# Server
NODE_ENV=development
PORT=3000
HOST=localhost

# SSE Configuration
SSE_TICK_INTERVAL=2000

# Heartbeat interval
SSE_HEARTBEAT_INTERVAL=30000

SSE_RETRY_TIMEOUT=3000

# Replay buffer configuration (SSRK-135)
# Maximum events to store in replay buffer
SSE_MAX_BUFFER_SIZE=1000

# Maximum events to replay in one batch (SSRK-138)
SSE_MAX_REPLAY_BATCH=100

# Buffer TTL in ms (0 = no expiry)
SSE_BUFFER_TTL_MS=0

# Connection Limits
MAX_CONNECTIONS=1000

# Shutdown
SHUTDOWN_GRACE_PERIOD=5000

# Logging
LOG_LEVEL=debug
LOG_HEARTBEATS=false
LOG_REPLAY=false
